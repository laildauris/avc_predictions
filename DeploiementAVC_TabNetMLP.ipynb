        "---\n",
        "## 🐙 ÉTAPE 5 – Push vers GitHub\n",
        "> **Prérequis :** Token GitHub avec droits `repo` défini à l'ÉTAPE 1"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "github_cell"},
      "source": [
        "# ══════════════════════════════════════════════════════════════════\n",
        "# 🐙 CRÉATION DU REPO ET PUSH GITHUB\n",
        "# ══════════════════════════════════════════════════════════════════\n",
        "\n",
        "from github import Github\n",
        "import os, base64\n",
        "\n",
        "# ── Contenu de l'app Streamlit ──\n",
        "APP_CODE = '''\n",
        "# app.py – Contenu complet chargé depuis le fichier local\n",
        "# (Le contenu complet de app.py sera inséré ici automatiquement)\n",
        "'''\n",
        "\n",
        "REQUIREMENTS = \"\"\"streamlit==1.32.0\n",
        "torch==2.2.0\n",
        "numpy==1.26.4\n",
        "pandas==2.2.1\n",
        "scikit-learn==1.4.1\n",
        "shap==0.44.1\n",
        "lime==0.2.0.1\n",
        "matplotlib==3.8.3\n",
        "seaborn==0.13.2\n",
        "plotly==5.20.0\n",
        "fpdf2==2.7.9\n",
        "\"\"\"\n",
        "\n",
        "STREAMLIT_CONFIG = \"\"\"[theme]\n",
        "base = \"dark\"\n",
        "primaryColor = \"#00d4ff\"\n",
        "backgroundColor = \"#0a1628\"\n",
        "secondaryBackgroundColor = \"#0f2040\"\n",
        "textColor = \"#e8f4fd\"\n",
        "font = \"sans serif\"\n",
        "\n",
        "[server]\n",
        "maxUploadSize = 200\n",
        "\"\"\"\n",
        "\n",
        "print(\"🐙 Connexion à GitHub...\")\n",
        "g = Github(GITHUB_TOKEN)\n",
        "user = g.get_user()\n",
        "print(f\"   Connecté en tant que : {user.login}\")\n",
        "\n",
        "# Créer ou récupérer le repo\n",
        "try:\n",
        "    repo = user.get_repo(REPO_NAME)\n",
        "    print(f\"   Repo existant trouvé : {repo.full_name}\")\n",
        "except:\n",
        "    repo = user.create_repo(\n",
        "        REPO_NAME,\n",
        "        description=\"🧠 Centre Neurologique AVC – Modèle Hybride TabNet-MLP | Dauris-Bouchra-Amine\",\n",
        "        private=False,\n",
        "        auto_init=True\n",
        "    )\n",
        "    print(f\"   ✅ Nouveau repo créé : {repo.full_name}\")\n",
        "\n",
        "def push_file(path, content, message, encoding='utf-8'):\n",
        "    \"\"\"Push ou met à jour un fichier dans le repo GitHub.\"\"\"\n",
        "    try:\n",
        "        existing = repo.get_contents(path)\n",
        "        repo.update_file(path, message, content, existing.sha)\n",
        "        print(f\"   🔄 Mis à jour : {path}\")\n",
        "    except:\n",
        "        repo.create_file(path, message, content)\n",
        "        print(f\"   ✅ Créé : {path}\")\n",
        "\n",
        "# Lire le fichier app.py local depuis Colab\n",
        "try:\n",
        "    with open('app.py', 'r', encoding='utf-8') as f:\n",
        "        app_content = f.read()\n",
        "    print(\"   ✓ app.py lu depuis le répertoire local\")\n",
        "except FileNotFoundError:\n",
        "    print(\"   ⚠️  app.py non trouvé localement – utilisez le code de l'étape précédente\")\n",
        "    app_content = APP_CODE\n",
        "\n",
        "print(\"\\n📤 Push des fichiers vers GitHub...\")\n",
        "push_file('app.py',                 app_content,    'Add: App Streamlit TabNet-MLP AVC')\n",
        "push_file('requirements.txt',       REQUIREMENTS,   'Add: Requirements')\n",
        "push_file('.streamlit/config.toml', STREAMLIT_CONFIG,'Add: Streamlit dark theme config')\n",
        "\n",
        "# Push des assets si disponibles\n",
        "for asset in ['training_curves.png', 'evaluation_results.png']:\n",
        "    if os.path.exists(asset):\n",
        "        with open(asset, 'rb') as f:\n",
        "            content = base64.b64encode(f.read()).decode()\n",
        "        # GitHub binary files\n",
        "        try:\n",
        "            existing = repo.get_contents(f'assets/{asset}')\n",
        "            repo.update_file(f'assets/{asset}', f'Update: {asset}',\n",
        "                             base64.b64decode(content), existing.sha)\n",
        "        except:\n",
        "            repo.create_file(f'assets/{asset}', f'Add: {asset}',\n",
        "                             base64.b64decode(content))\n",
        "        print(f\"   ✅ Asset pushé : assets/{asset}\")\n",
        "\n",
        "print(f\"\\n🎉 Push terminé !\")\n",
        "print(f\"   🔗 URL du repo : https://github.com/{GITHUB_USERNAME}/{REPO_NAME}\")\n",
        "print(f\"   📁 Fichiers dans le repo : {[c.name for c in repo.get_contents('')]}\")"
      ],
      "execution_count": null,
      "outputs": []
